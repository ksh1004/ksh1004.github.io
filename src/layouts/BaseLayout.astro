---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'AI/Data 엔지니어 김순하의 기술 블로그' } = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <!-- JetBrains Mono 폰트 -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
  </head>
  <body class="scanlines">
    <!-- 네비게이션 -->
    <nav class="border-b border-[#1a1a2e] bg-[#0a0a0f]/90 backdrop-blur-sm sticky top-0 z-50">
      <div class="max-w-4xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="neon-text font-bold text-lg tracking-wider hover:opacity-80 transition-opacity">
          ksh1004<span class="cursor"></span>
        </a>
        <div class="flex gap-6 text-sm text-[#666680]">
          <a href="/posts" class="hover:text-[#00ff88] transition-colors">/posts</a>
          <a href="/about" class="hover:text-[#00ff88] transition-colors">/about</a>
          <a href="https://velog.io/@ksh1004" target="_blank" rel="noopener" class="hover:text-[#ffc20e] transition-colors">/velog ↗</a>
          <a href="https://github.com/ksh1004" target="_blank" rel="noopener" class="hover:text-[#ffc20e] transition-colors">/github ↗</a>
        </div>
      </div>
    </nav>

    <!-- 메인 콘텐츠 -->
    <main class="max-w-4xl mx-auto px-6 py-12">
      <slot />
    </main>

    <!-- 푸터 -->
    <footer class="border-t border-[#1a1a2e] mt-20">
      <div class="max-w-4xl mx-auto px-6 py-8 text-center text-[#666680] text-sm">
        <span class="neon-text">KIM SOONHA</span> &nbsp;·&nbsp; AI / Data / OSINT
        &nbsp;·&nbsp; <a href="https://github.com/ksh1004" class="hover:text-[#ffc20e] transition-colors">GitHub</a>
      </div>
    </footer>
  </body>
</html>
