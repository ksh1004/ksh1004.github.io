---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogType?: string;
}
const { title, description = '김순하 — 개발·금융·정보분석 블로그', ogType = 'website' } = Astro.props;
const pathname = Astro.url.pathname;
const canonical = new URL(pathname, Astro.site);
---

<!doctype html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="theme-color" content="#07090a" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href={canonical} />
  <link rel="alternate" type="application/rss+xml" title="KSH1004 RSS" href="/rss.xml" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="KSH1004" />
  <meta property="og:locale" content="ko_KR" />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;700&display=swap" rel="stylesheet" />
</head>

<body>
  <!-- 배경 지구본 -->
  <canvas id="globe-bg" style="position:fixed;top:0;left:0;width:100vw;height:100vh;z-index:1;pointer-events:none;opacity:0.13;mix-blend-mode:screen;"></canvas>

  <!-- 필름 그레인 -->
  <div class="grain-overlay" aria-hidden="true"></div>

  <div class="cursor-dot" id="cursor-dot"></div>
  <div class="cursor-ring" id="cursor-ring"></div>

  <!-- 상단 상태바 -->
  <div style="position:relative;z-index:2;background:#050708;border-bottom:1px solid var(--hairline);padding:5px 40px;display:flex;align-items:center;justify-content:space-between;">
    <span></span>
    <span id="clock" style="font-size:10px;letter-spacing:1px;color:var(--muted);"></span>
  </div>

  <!-- NAV -->
  <nav style="position:sticky;top:0;z-index:100;background:var(--canvas);border-bottom:1px solid var(--hairline);">
    <div class="intel-stripe"></div>
    <div style="max-width:1440px;margin:0 auto;padding:0 40px;height:58px;display:flex;align-items:center;justify-content:space-between;">

      <!-- 로고: 나침반 (thin needle style) -->
      <a href="/" style="display:flex;align-items:center;gap:0;text-decoration:none;" data-cursor-hover>
        <svg width="30" height="30" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" style="color:var(--green);">
          <!-- 외곽 베젤 링 -->
          <circle cx="20" cy="20" r="18.5" stroke="currentColor" stroke-width="0.7" opacity="0.5"/>
          <!-- 베젤 눈금 16개 -->
          <line x1="20" y1="1.5"  x2="20"   y2="5.8"  stroke="currentColor" stroke-width="1.6"/>
          <line x1="27.1" y1="2.9" x2="26.3" y2="4.8"  stroke="currentColor" stroke-width="0.6" opacity="0.38"/>
          <line x1="33.1" y1="6.9" x2="30.8" y2="9.2"  stroke="currentColor" stroke-width="1"   opacity="0.6"/>
          <line x1="37.1" y1="12.9" x2="35.2" y2="13.7" stroke="currentColor" stroke-width="0.6" opacity="0.38"/>
          <line x1="38.5" y1="20"  x2="34.2" y2="20"   stroke="currentColor" stroke-width="1"   opacity="0.6"/>
          <line x1="37.1" y1="27.1" x2="35.2" y2="26.3" stroke="currentColor" stroke-width="0.6" opacity="0.38"/>
          <line x1="33.1" y1="33.1" x2="30.8" y2="30.8" stroke="currentColor" stroke-width="1"   opacity="0.6"/>
          <line x1="27.1" y1="37.1" x2="26.3" y2="35.2" stroke="currentColor" stroke-width="0.6" opacity="0.38"/>
          <line x1="20"   y1="38.5" x2="20"   y2="34.2" stroke="currentColor" stroke-width="1"   opacity="0.6"/>
          <line x1="12.9" y1="37.1" x2="13.7" y2="35.2" stroke="currentColor" stroke-width="0.6" opacity="0.38"/>
          <line x1="6.9"  y1="33.1" x2="9.2"  y2="30.8" stroke="currentColor" stroke-width="1"   opacity="0.6"/>
          <line x1="2.9"  y1="27.1" x2="4.8"  y2="26.3" stroke="currentColor" stroke-width="0.6" opacity="0.38"/>
          <line x1="1.5"  y1="20"   x2="5.8"  y2="20"   stroke="currentColor" stroke-width="1"   opacity="0.6"/>
          <line x1="2.9"  y1="12.9" x2="4.8"  y2="13.7" stroke="currentColor" stroke-width="0.6" opacity="0.38"/>
          <line x1="6.9"  y1="6.9"  x2="9.2"  y2="9.2"  stroke="currentColor" stroke-width="1"   opacity="0.6"/>
          <line x1="12.9" y1="2.9"  x2="13.7" y2="4.8"  stroke="currentColor" stroke-width="0.6" opacity="0.38"/>
          <!-- 내부 링 -->
          <circle cx="20" cy="20" r="12" stroke="currentColor" stroke-width="0.45" opacity="0.2"/>
          <!-- 바늘: N (가장 밝고 굵음) -->
          <line x1="20" y1="20" x2="20"  y2="8.5"  stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <!-- N 끝 삼각 표시자 -->
          <polygon points="20,6.5 18.5,9.5 21.5,9.5" fill="currentColor"/>
          <!-- 바늘: S (반대쪽, 얇고 흐림) -->
          <line x1="20" y1="20" x2="20"  y2="31.5" stroke="currentColor" stroke-width="1"   stroke-linecap="round" opacity="0.32"/>
          <!-- 바늘: E / W -->
          <line x1="20" y1="20" x2="31.5" y2="20"  stroke="currentColor" stroke-width="0.9" stroke-linecap="round" opacity="0.38"/>
          <line x1="20" y1="20" x2="8.5"  y2="20"  stroke="currentColor" stroke-width="0.9" stroke-linecap="round" opacity="0.38"/>
          <!-- 대각선 바늘 (NE/SE/SW/NW) 더 짧고 가늘게 -->
          <line x1="20" y1="20" x2="27.5" y2="12.5" stroke="currentColor" stroke-width="0.6" stroke-linecap="round" opacity="0.22"/>
          <line x1="20" y1="20" x2="27.5" y2="27.5" stroke="currentColor" stroke-width="0.6" stroke-linecap="round" opacity="0.22"/>
          <line x1="20" y1="20" x2="12.5" y2="27.5" stroke="currentColor" stroke-width="0.6" stroke-linecap="round" opacity="0.22"/>
          <line x1="20" y1="20" x2="12.5" y2="12.5" stroke="currentColor" stroke-width="0.6" stroke-linecap="round" opacity="0.22"/>
          <!-- 중심 링 + 점 -->
          <circle cx="20" cy="20" r="3.5" stroke="currentColor" stroke-width="0.6" opacity="0.35"/>
          <circle cx="20" cy="20" r="1.4" fill="currentColor"/>
        </svg>
      </a>

      <!-- 네비 -->
      <div style="display:flex;align-items:center;gap:32px;">
        {[
          { href: '/posts', label: 'Posts' },
          { href: '/profile', label: 'Profile' },
          { href: 'https://velog.io/@ksh1004', label: 'Velog', ext: true },
          { href: 'https://github.com/ksh1004', label: 'GitHub', ext: true },
        ].map(l => {
          const active = !l.ext && (l.href === '/' ? pathname === '/' : pathname.startsWith(l.href));
          return (
            <a href={l.href}
               target={l.ext ? '_blank' : undefined}
               rel={l.ext ? 'noopener' : undefined}
               style={`font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;text-decoration:none;transition:color 0.15s;padding-bottom:3px;color:${active?'var(--ink)':'var(--muted)'};border-bottom:${active?'1px solid var(--green)':'1px solid transparent'};`}
               onmouseover="this.style.color='var(--green)'"
               onmouseout={active ? "this.style.color='var(--ink)'" : "this.style.color='var(--muted)'"}
               data-cursor-hover>
              {l.label}
            </a>
          );
        })}
      </div>
    </div>
  </nav>

  <div style="position:relative;z-index:2;">
    <slot />
  </div>

  <!-- FOOTER -->
  <footer style="position:relative;z-index:2;background:#050708;border-top:1px solid var(--hairline);padding:60px 40px 40px;">
    <div class="intel-stripe" style="margin-bottom:48px;"></div>
    <div style="max-width:1440px;margin:0 auto;display:flex;align-items:flex-start;justify-content:space-between;gap:40px;flex-wrap:wrap;">
      <div>
        <div style="font-size:13px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--ink);margin-bottom:6px;">KIM SOONHA</div>
        <div style="font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:16px;">개발 · 금융 · 정보분석</div>
        <div style="font-size:12px;font-weight:300;color:var(--muted);line-height:1.8;">Seoul, Republic of Korea</div>
      </div>
      <div style="display:flex;gap:64px;flex-wrap:wrap;">
        {[
          { label: 'Navigation', links: [{ t: 'Posts', h: '/posts' }, { t: 'Profile', h: '/profile' }] },
          { label: 'External',   links: [{ t: 'GitHub', h: 'https://github.com/ksh1004' }, { t: 'Velog', h: 'https://velog.io/@ksh1004' }, { t: 'Email', h: 'mailto:soonha990@naver.com' }] },
        ].map(col => (
          <div>
            <div style="font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:16px;">{col.label}</div>
            <div style="display:flex;flex-direction:column;gap:12px;">
              {col.links.map(l => (
                <a href={l.h} style="font-size:12px;font-weight:300;color:var(--body);text-decoration:none;letter-spacing:0.5px;transition:color 0.15s;"
                   onmouseover="this.style.color='var(--green)'" onmouseout="this.style.color='var(--body)'">{l.t}</a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
    <div style="max-width:1440px;margin:40px auto 0;padding-top:24px;border-top:1px solid var(--hairline);">
      <span style="font-size:10px;letter-spacing:1px;color:var(--hairline-strong);">© 2026 Kim SoonHa</span>
    </div>
  </footer>
</body>
</html>

<script>
import gsap from 'gsap';
import { ScrollTrigger } from 'gsap/ScrollTrigger';
import { geoOrthographic, geoPath, geoGraticule, geoDistance } from 'd3-geo';
import { feature } from 'topojson-client';

const CITIES = [
  { lat: 37.5,  lon: 127.0, label: 'SEL' },
  { lat: 39.0,  lon: 125.7, label: 'PYG' },
  { lat: 39.9,  lon: 116.4, label: 'BJG' },
  { lat: 35.7,  lon: 139.7, label: 'TKY' },
  { lat: 38.9,  lon: -77.0, label: 'WDC' },
  { lat: 55.7,  lon:  37.6, label: 'MSC' },
  { lat: 51.5,  lon:  -0.1, label: 'LON' },
  { lat: 48.9,  lon:   2.3, label: 'PAR' },
];
gsap.registerPlugin(ScrollTrigger);

/* ── 시계 (KST·UTC 이중 표기) ── */
function tick() {
  const now = new Date();
  const kst = new Date(now.getTime() + 9 * 3600 * 1000);
  const p = (n: number) => String(n).padStart(2, '0');
  const el = document.getElementById('clock');
  if (el) el.textContent =
    `${now.getUTCFullYear()}.${p(now.getUTCMonth()+1)}.${p(now.getUTCDate())} · ` +
    `KST ${p(kst.getUTCHours())}:${p(kst.getUTCMinutes())}:${p(kst.getUTCSeconds())} · ` +
    `UTC ${p(now.getUTCHours())}:${p(now.getUTCMinutes())}:${p(now.getUTCSeconds())}`;
}
tick(); setInterval(tick, 1000);

/* ── 텍스트 복호화 효과 ── */
const GLYPHS = '!<>-_\\/[]{}=+*^?#01';
function decryptEl(el: HTMLElement) {
  const finalText = el.innerText;
  if (!finalText.trim()) return;
  const total = Math.max(30, finalText.length * 3);
  let frame = 0;
  function step() {
    frame++;
    const resolved = Math.floor(finalText.length * (frame / total));
    let out = '';
    for (let i = 0; i < finalText.length; i++) {
      const ch = finalText[i];
      if (ch === '\n' || ch === ' ') { out += ch; continue; }
      out += i < resolved ? ch : GLYPHS[(Math.random() * GLYPHS.length) | 0];
    }
    el.innerText = out;
    if (resolved < finalText.length) requestAnimationFrame(step);
    else el.innerText = finalText;
  }
  step();
}
document.querySelectorAll<HTMLElement>('[data-decrypt]').forEach(decryptEl);

/* ── 커서 (마우스 환경에서만 활성화) ── */
const finePointer = window.matchMedia('(pointer: fine)').matches;
const dot  = document.getElementById('cursor-dot')!;
const ring = document.getElementById('cursor-ring')!;
if (finePointer) {
  window.addEventListener('mousemove', e => {
    gsap.to(dot,  { x: e.clientX, y: e.clientY, duration: 0.05 });
    gsap.to(ring, { x: e.clientX, y: e.clientY, duration: 0.25, ease: 'power2.out' });
  });
  document.querySelectorAll('[data-cursor-hover], a, button').forEach(el => {
    el.addEventListener('mouseenter', () => ring.classList.add('hover'));
    el.addEventListener('mouseleave', () => ring.classList.remove('hover'));
  });
  document.addEventListener('mouseleave', () => gsap.to([dot, ring], { opacity: 0, duration: 0.2 }));
  document.addEventListener('mouseenter', () => gsap.to([dot, ring], { opacity: 1, duration: 0.2 }));
} else {
  dot.style.display = 'none';
  ring.style.display = 'none';
}

/* ── 스크롤 애니메이션 ── */
gsap.utils.toArray<HTMLElement>('.gsap-reveal').forEach(el => {
  gsap.from(el, { y: 30, opacity: 0, duration: 0.7, ease: 'power3.out',
    scrollTrigger: { trigger: el, start: 'top 88%', toggleActions: 'play none none none' } });
});
gsap.utils.toArray<HTMLElement>('.gsap-stagger').forEach(parent => {
  gsap.from(Array.from(parent.children), { y: 20, opacity: 0, duration: 0.5, stagger: 0.06, ease: 'power3.out',
    scrollTrigger: { trigger: parent, start: 'top 85%', toggleActions: 'play none none none' } });
});
gsap.utils.toArray<HTMLElement>('.gsap-line').forEach(el => {
  gsap.from(el, { scaleX: 0, transformOrigin: 'left', duration: 0.8, ease: 'power4.out',
    scrollTrigger: { trigger: el, start: 'top 92%', toggleActions: 'play none none none' } });
});

/* ── 배경 지구본 ── */
const globeCanvas = document.getElementById('globe-bg') as HTMLCanvasElement;
const globeCtx = globeCanvas?.getContext('2d');

if (globeCanvas && globeCtx) {
  let cssW = 0, cssH = 0;

  function resizeGlobe() {
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    cssW = window.innerWidth;
    cssH = window.innerHeight;
    globeCanvas.width  = cssW * dpr;
    globeCanvas.height = cssH * dpr;
    globeCtx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }
  resizeGlobe();
  window.addEventListener('resize', resizeGlobe);

  let rotX = 0;
  let worldData: any = null;
  let rafId = 0;

  function drawGlobe() {
    const W = cssW, H = cssH;
    globeCtx.clearRect(0, 0, W, H);

    const scale = Math.min(W, H) * 0.44;

    const projection = geoOrthographic()
      .scale(scale)
      .translate([W / 2, H / 2])
      .rotate([rotX, -20, 0])
      .clipAngle(90);

    const pathGen = geoPath(projection, globeCtx);

    // ── 중앙 방사형 글로우 ──
    const radGlow = globeCtx.createRadialGradient(W/2, H/2, 0, W/2, H/2, scale * 1.1);
    radGlow.addColorStop(0, 'rgba(78,124,54,0.06)');
    radGlow.addColorStop(1, 'rgba(78,124,54,0)');
    globeCtx.fillStyle = radGlow;
    globeCtx.fillRect(0, 0, W, H);

    // ── 지구 외곽선 ──
    globeCtx.beginPath();
    pathGen({ type: 'Sphere' } as any);
    globeCtx.strokeStyle = 'rgba(78,124,54,0.3)';
    globeCtx.lineWidth = 0.8;
    globeCtx.stroke();

    // ── 위경도 그물망 ──
    const graticule = geoGraticule()();
    globeCtx.beginPath();
    pathGen(graticule);
    globeCtx.strokeStyle = 'rgba(78,124,54,0.055)';
    globeCtx.lineWidth = 0.3;
    globeCtx.stroke();

    // ── 대륙 윤곽선 ──
    if (worldData) {
      const land = feature(worldData, worldData.objects.land as any);
      globeCtx.beginPath();
      pathGen(land as any);
      globeCtx.strokeStyle = 'rgba(78,124,54,0.82)';
      globeCtx.lineWidth = 0.65;
      globeCtx.stroke();
    }

    // ── 코너 HUD 브래킷 ──
    const bSize = Math.min(W, H) * 0.055;
    const bM    = Math.min(W, H) * 0.035;
    const corners: [number, number, number, number][] = [
      [bM, bM, 1, 1], [W-bM, bM, -1, 1],
      [W-bM, H-bM, -1, -1], [bM, H-bM, 1, -1],
    ];
    globeCtx.strokeStyle = 'rgba(78,124,54,0.42)';
    globeCtx.lineWidth = 1.1;
    corners.forEach(([x, y, dx, dy]) => {
      globeCtx.beginPath();
      globeCtx.moveTo(x + dx * bSize, y);
      globeCtx.lineTo(x, y);
      globeCtx.lineTo(x, y + dy * bSize);
      globeCtx.stroke();
    });

    // ── 수평 스캔라인 ──
    const scanY = ((Date.now() * 0.028) % (H + 60)) - 30;
    const scanGrad = globeCtx.createLinearGradient(0, scanY - 6, 0, scanY + 6);
    scanGrad.addColorStop(0,   'rgba(78,124,54,0)');
    scanGrad.addColorStop(0.5, 'rgba(78,124,54,0.1)');
    scanGrad.addColorStop(1,   'rgba(78,124,54,0)');
    globeCtx.fillStyle = scanGrad;
    globeCtx.fillRect(0, scanY - 6, W, 12);

    // ── HUD 데이터 텍스트 ──
    globeCtx.font = '10px "IBM Plex Mono", monospace';
    globeCtx.fillStyle = 'rgba(78,124,54,0.28)';
    globeCtx.fillText('37°33\'N  127°00\'E', bM + 4, H - bM - 6);
    globeCtx.fillText(`ROT ${(((rotX % 360) + 360) % 360).toFixed(1)}°`, W - bM - 72, H - bM - 6);
    globeCtx.fillText('SIG ▮▮▮▮▯', bM + 4, bM + 14);

    // ── 도시 마커 ──
    const globeCenter: [number, number] = [-(rotX % 360), 20];
    const pulse = 0.5 + 0.5 * Math.sin(Date.now() * 0.003);
    CITIES.forEach(({ lat, lon, label }) => {
      if (geoDistance(globeCenter, [lon, lat]) >= Math.PI / 2) return;
      const pt = projection([lon, lat]);
      if (!pt) return;
      const [px, py] = pt;

      globeCtx.beginPath();
      globeCtx.arc(px, py, 3.5 + 3 * pulse, 0, Math.PI * 2);
      globeCtx.strokeStyle = `rgba(78,124,54,${0.28 * pulse})`;
      globeCtx.lineWidth = 0.8;
      globeCtx.stroke();

      globeCtx.beginPath();
      globeCtx.arc(px, py, 1.8, 0, Math.PI * 2);
      globeCtx.fillStyle = 'rgba(78,124,54,0.9)';
      globeCtx.fill();

      globeCtx.font = '9px "IBM Plex Mono", monospace';
      globeCtx.fillStyle = 'rgba(78,124,54,0.55)';
      globeCtx.fillText(label, px + 4, py + 3);
    });

    rotX += 0.02;
    rafId = requestAnimationFrame(drawGlobe);
  }

  fetch('/world-110m.json')
    .then(r => r.json())
    .then(data => { worldData = data; })
    .catch(() => {});

  drawGlobe();
}
</script>
