---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: Date;
  tags?: string[];
  description?: string;
}

const { title, date, tags = [], description } = Astro.props;
const formattedDate = date.toLocaleDateString('ko-KR', { year: 'numeric', month: '2-digit', day: '2-digit' });
---

<BaseLayout title={`${title} | ksh1004`} description={description}>
  <article>
    <!-- 글 헤더 -->
    <header class="mb-10 pb-8 border-b border-[#1a1a2e]">
      <div class="text-[#666680] text-sm mb-3">
        <span class="text-[#00ff88]">~/posts</span> &gt; {title}
      </div>
      <h1 class="text-3xl font-bold text-[#e0e0e0] mb-4 leading-tight">{title}</h1>
      <div class="flex items-center gap-4 text-sm text-[#666680]">
        <span>{formattedDate}</span>
        {tags.length > 0 && (
          <div class="flex gap-2">
            {tags.map(tag => (
              <span class="border border-[#1a1a2e] px-2 py-0.5 text-xs text-[#00ff88] rounded">
                #{tag}
              </span>
            ))}
          </div>
        )}
      </div>
    </header>

    <!-- 글 본문 -->
    <div class="prose prose-invert leading-relaxed">
      <slot />
    </div>

    <!-- 하단 네비게이션 -->
    <div class="mt-12 pt-8 border-t border-[#1a1a2e]">
      <a href="/posts" class="text-[#666680] hover:text-[#00ff88] transition-colors text-sm">
        ← /posts 목록으로
      </a>
    </div>
  </article>
</BaseLayout>
