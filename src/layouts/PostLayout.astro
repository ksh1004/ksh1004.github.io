---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: Date;
  tags?: string[];
  description?: string;
}

const { title, date, tags = [], description } = Astro.props;
const formatted = date.toLocaleDateString('ko-KR', { year: 'numeric', month: '2-digit', day: '2-digit' });
---

<BaseLayout title={`${title} — KSH1004`} description={description}>
  <article style="max-width:1200px;margin:0 auto;padding:4rem 2rem 8rem;">

    <!-- 브레드크럼 -->
    <div class="gsap-reveal" style="margin-bottom:3rem;">
      <a href="/posts" style="font-family:'Barlow Condensed',sans-serif;font-size:0.7rem;letter-spacing:0.2em;text-transform:uppercase;color:#8a7888;text-decoration:none;transition:color 0.2s;"
         onmouseover="this.style.color='#FFC20E'"
         onmouseout="this.style.color='#8a7888'"
         data-cursor-hover>
        ← Posts
      </a>
    </div>

    <!-- 글 헤더 -->
    <header style="margin-bottom:4rem;">
      <div class="gsap-reveal">
        <div class="section-label" style="margin-bottom:1rem;">{formatted}</div>
        <h1 style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(2.5rem,6vw,5rem);font-weight:800;text-transform:uppercase;letter-spacing:0.02em;color:#f0e6d0;line-height:1;margin-bottom:1.5rem;">
          {title}
        </h1>
      </div>

      {tags.length > 0 && (
        <div class="gsap-reveal" style="display:flex;gap:0.6rem;flex-wrap:wrap;">
          {tags.map(tag => (
            <span style="font-family:'Barlow Condensed',sans-serif;font-size:0.65rem;letter-spacing:0.2em;text-transform:uppercase;color:#8a7888;border:1px solid #3d2f3d;padding:0.25rem 0.6rem;">
              {tag}
            </span>
          ))}
        </div>
      )}

      <hr class="gsap-line" style="border:none;border-top:1px solid #3d2f3d;margin-top:2.5rem;" />
    </header>

    <!-- 본문 -->
    <div class="prose gsap-reveal">
      <slot />
    </div>

  </article>
</BaseLayout>
