---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: Date;
  tags?: string[];
  description?: string;
}
const { title, date, tags = [], description } = Astro.props;
const fmt = date.toLocaleDateString('ko-KR', { year: 'numeric', month: '2-digit', day: '2-digit' });
---

<BaseLayout title={`${title} — KSH1004`} description={description}>
  <article style="max-width:1440px;margin:0 auto;padding:64px 40px 96px;">

    <!-- 브레드크럼 -->
    <div class="gsap-reveal" style="margin-bottom:48px;">
      <a href="/posts" style="font-size:14px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:#7e7e7e;text-decoration:none;transition:color 0.15s;"
         onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#7e7e7e'" data-cursor-hover>
        ← All Posts
      </a>
    </div>

    <!-- 글 헤더 -->
    <header style="max-width:900px;margin-bottom:64px;">
      <div class="gsap-reveal">
        <div style="font-size:12px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:#7e7e7e;margin-bottom:16px;">
          {fmt}
        </div>
        <h1 style="font-size:clamp(2.5rem,5vw,4rem);font-weight:700;text-transform:uppercase;color:#fff;line-height:1.05;margin-bottom:24px;">
          {title}
        </h1>
        {description && (
          <p style="font-size:18px;font-weight:300;color:#bbbbbb;line-height:1.5;">{description}</p>
        )}
      </div>

      {tags.length > 0 && (
        <div class="gsap-reveal" style="display:flex;gap:8px;flex-wrap:wrap;margin-top:24px;">
          {tags.map(tag => (
            <span style="font-size:12px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:#7e7e7e;border:1px solid #3c3c3c;padding:6px 12px;border-radius:0;">
              {tag}
            </span>
          ))}
        </div>
      )}

      <!-- M 스트라이프 구분선 -->
      <div class="m-stripe gsap-line" style="margin-top:40px;"><span></span><span></span><span></span></div>
    </header>

    <!-- 본문 -->
    <div class="prose gsap-reveal" style="max-width:720px;">
      <slot />
    </div>

    <!-- 하단 -->
    <div style="margin-top:80px;padding-top:40px;border-top:1px solid #3c3c3c;" class="gsap-reveal">
      <a href="/posts" style="font-size:14px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:#7e7e7e;text-decoration:none;transition:color 0.15s;"
         onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#7e7e7e'" data-cursor-hover>
        ← Back to Posts
      </a>
    </div>
  </article>
</BaseLayout>
