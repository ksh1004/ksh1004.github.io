---
import BaseLayout from '../layouts/BaseLayout.astro';

const specs = [
  { val: 'Seoul', label: 'Location' },
  { val: '인하대', label: 'University' },
  { val: '개발', label: 'Focus' },
  { val: '2026', label: 'Year' },
];

const interests = [
  { num: '01', name: '개발 / 엔지니어링', desc: '파이썬, 데이터 파이프라인, 백엔드 시스템 개발' },
  { num: '02', name: '금융 / 퀀트', desc: '시스템 트레이딩, 백테스팅, 시장 데이터 분석' },
  { num: '03', name: '정보 분석', desc: '공개출처정보(OSINT) 수집·분석·시각화' },
  { num: '04', name: '프로젝트 기록', desc: '개발 과정, 실험, 삽질 기록' },
];

const skills = ['Python', 'PyTorch', 'Pandas', 'NumPy', 'SQL', 'Streamlit', 'FastAPI', 'Docker', 'Git', 'Linux'];
---

<BaseLayout title="Profile — KSH1004">

  <!-- 히어로 -->
  <section style="background:var(--canvas);padding:96px 40px;border-bottom:1px solid var(--hairline);position:relative;overflow:hidden;">
    <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(28,46,74,0.3) 1px,transparent 1px),linear-gradient(90deg,rgba(28,46,74,0.3) 1px,transparent 1px);background-size:64px 64px;pointer-events:none;"></div>
    <div style="max-width:1440px;margin:0 auto;position:relative;z-index:1;">
      <div class="gsap-reveal">
        <div style="font-size:10px;letter-spacing:2.5px;text-transform:uppercase;color:var(--muted);margin-bottom:16px;">
          // SUBJECT PROFILE //
        </div>
        <h1 style="font-size:clamp(3.5rem,9vw,7.5rem);font-weight:700;text-transform:uppercase;color:var(--ink);line-height:0.95;letter-spacing:-0.01em;">
          KIM<br/>SOONHA.
        </h1>
      </div>
      <div class="intel-stripe gsap-line" style="margin-top:40px;"></div>
    </div>
  </section>

  <!-- 스펙 셀 -->
  <section style="background:var(--surface-soft);border-bottom:1px solid var(--hairline);">
    <div style="max-width:1440px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);">
      {specs.map((s, i) => (
        <div class="spec-cell" style={`border-radius:0;border:none;border-right:${i<3?'1px solid var(--hairline)':'none'};`}>
          <div class="val">{s.val}</div>
          <div class="spec-label">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- 소개 -->
  <section style="background:var(--canvas);padding:96px 40px;border-bottom:1px solid var(--hairline);">
    <div style="max-width:1440px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:96px;align-items:start;">
      <div class="gsap-reveal">
        <div style="font-size:10px;letter-spacing:2.5px;text-transform:uppercase;color:var(--muted);margin-bottom:24px;">// Introduction</div>
        <p style="font-size:16px;font-weight:400;color:var(--body-strong);line-height:1.8;letter-spacing:0.3px;">
          AI/Data 엔지니어를 목표로 하는 학부생입니다.
        </p>
        <p style="font-size:14px;font-weight:300;color:var(--body);line-height:1.9;margin-top:16px;letter-spacing:0.3px;">
          머신러닝 모델 개발부터 금융 데이터 분석, 한반도 OSINT 모니터링 시스템까지 — 데이터가 실제 문제를 해결하는 과정에 관심이 있습니다. 배운 것을 기록하고 만든 것을 공유합니다.
        </p>
      </div>
      <div class="gsap-reveal">
        <div style="font-size:10px;letter-spacing:2.5px;text-transform:uppercase;color:var(--muted);margin-bottom:24px;">// Contact</div>
        <div style="display:flex;flex-direction:column;gap:0;">
          {[
            { label: 'GitHub',  val: 'github.com/ksh1004',   href: 'https://github.com/ksh1004' },
            { label: 'Velog',   val: 'velog.io/@ksh1004',    href: 'https://velog.io/@ksh1004' },
            { label: 'Email',   val: 'soonha990@naver.com',  href: 'mailto:soonha990@naver.com' },
          ].map((item, i, arr) => (
            <a href={item.href} target={item.href.startsWith('http')?'_blank':undefined} rel="noopener"
               style={`display:flex;justify-content:space-between;align-items:baseline;gap:24px;padding:20px 0;border-bottom:${i<arr.length-1?'1px solid var(--hairline)':'none'};text-decoration:none;transition:background 0.15s;`}
               data-cursor-hover
               onmouseover="this.querySelector('.cv').style.color='#c8963c'" onmouseout="this.querySelector('.cv').style.color='var(--body)'">
              <span style="font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--muted);">{item.label}</span>
              <span class="cv" style="font-size:13px;font-weight:300;color:var(--body);transition:color 0.15s;letter-spacing:0.5px;">{item.val} →</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- 관심 분야 -->
  <section style="background:var(--surface-soft);padding:96px 40px;border-bottom:1px solid var(--hairline);">
    <div style="max-width:1440px;margin:0 auto;">
      <div class="gsap-reveal" style="margin-bottom:40px;">
        <div style="font-size:10px;letter-spacing:2.5px;text-transform:uppercase;color:var(--muted);margin-bottom:12px;">// Areas</div>
        <h2 style="font-size:clamp(1.8rem,4vw,3rem);font-weight:700;text-transform:uppercase;color:var(--ink);line-height:1.1;letter-spacing:1px;">Of Interest</h2>
      </div>
      <div class="intel-stripe gsap-line" style="margin-bottom:1px;"></div>
      <div class="gsap-stagger" style="display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:var(--hairline);">
        {interests.map(item => (
          <div style="background:var(--surface-soft);padding:32px;">
            <div style="font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:16px;">{item.num}</div>
            <div style="font-size:20px;font-weight:700;text-transform:uppercase;color:var(--ink);margin-bottom:12px;line-height:1.2;letter-spacing:0.5px;">{item.name}</div>
            <div style="font-size:13px;font-weight:300;color:var(--body);line-height:1.7;letter-spacing:0.3px;">{item.desc}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 기술 스택 -->
  <section style="background:var(--canvas);padding:96px 40px;">
    <div style="max-width:1440px;margin:0 auto;">
      <div class="gsap-reveal" style="margin-bottom:40px;">
        <div style="font-size:10px;letter-spacing:2.5px;text-transform:uppercase;color:var(--muted);margin-bottom:12px;">// Technical</div>
        <h2 style="font-size:clamp(1.8rem,4vw,3rem);font-weight:700;text-transform:uppercase;color:var(--ink);line-height:1.1;letter-spacing:1px;">Stack</h2>
      </div>
      <div class="gsap-stagger" style="display:flex;flex-wrap:wrap;gap:1px;background:var(--hairline);">
        {skills.map(s => (
          <div style="background:var(--canvas);padding:18px 28px;font-size:12px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--muted);transition:background 0.15s,color 0.15s;"
               onmouseover="this.style.background='var(--surface-elevated)';this.style.color='#c8963c'"
               onmouseout="this.style.background='var(--canvas)';this.style.color='var(--muted)'">
            {s}
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
