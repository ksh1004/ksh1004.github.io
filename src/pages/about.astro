---
import BaseLayout from '../layouts/BaseLayout.astro';

const skills = ['Python', 'PyTorch', 'Pandas', 'SQL', 'Streamlit', 'FastAPI', 'Docker', 'Git', 'Linux'];

const interests = [
  { num: '01', label: 'AI / ML', desc: '머신러닝, 딥러닝, 자연어처리' },
  { num: '02', label: '금융 분석', desc: '시스템 트레이딩, 퀀트 백테스팅' },
  { num: '03', label: 'OSINT', desc: '공개출처정보 수집 및 시각화' },
  { num: '04', label: '국방·안보', desc: '한반도 데이터 분석' },
];
---

<BaseLayout title="About — KSH1004">
  <section style="max-width:1200px;margin:0 auto;padding:5rem 2rem 8rem;">

    <!-- 헤더 -->
    <div class="gsap-reveal" style="margin-bottom:5rem;">
      <div class="section-label" style="margin-bottom:0.5rem;">Profile</div>
      <h1 style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(3rem,8vw,6rem);font-weight:800;text-transform:uppercase;color:#f0e6d0;line-height:1;">
        KIM<br/><span style="color:#FFC20E;">SOONHA</span>
      </h1>
    </div>

    <hr class="gsap-line" style="border:none;border-top:1px solid #3d2f3d;margin-bottom:5rem;" />

    <!-- 소개 -->
    <div class="gsap-reveal" style="display:grid;grid-template-columns:1fr 1fr;gap:5rem;margin-bottom:6rem;align-items:start;">
      <div>
        <div class="section-label" style="margin-bottom:1rem;">Introduction</div>
        <p style="font-size:0.95rem;color:#c8bbaa;line-height:1.9;">
          AI/Data 엔지니어를 목표로 하는 학부생입니다.<br/><br/>
          머신러닝 모델 개발부터 금융 데이터 분석, 한반도 OSINT 모니터링 시스템까지
          데이터가 실제 문제를 해결하는 과정에 관심이 있습니다.
        </p>
      </div>
      <div>
        <div class="section-label" style="margin-bottom:1rem;">Contact</div>
        <div style="display:flex;flex-direction:column;gap:1rem;">
          {[
            { label: 'GitHub', val: 'github.com/ksh1004', href: 'https://github.com/ksh1004' },
            { label: 'Velog',  val: 'velog.io/@ksh1004',  href: 'https://velog.io/@ksh1004' },
            { label: 'Email',  val: 'soonha990@naver.com', href: 'mailto:soonha990@naver.com' },
          ].map(item => (
            <div style="display:flex;gap:1.5rem;align-items:baseline;">
              <span style="font-family:'Barlow Condensed',sans-serif;font-size:0.65rem;letter-spacing:0.2em;text-transform:uppercase;color:#FFC20E;width:3.5rem;flex-shrink:0;">{item.label}</span>
              <a href={item.href} target={item.href.startsWith('http') ? '_blank' : undefined} rel="noopener"
                 style="font-size:0.85rem;color:#8a7888;text-decoration:none;transition:color 0.2s;"
                 onmouseover="this.style.color='#f0e6d0'"
                 onmouseout="this.style.color='#8a7888'"
                 data-cursor-hover>
                {item.val} ↗
              </a>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- 관심 분야 -->
    <div class="gsap-reveal" style="margin-bottom:5rem;">
      <div class="section-label" style="margin-bottom:2rem;">Areas of Interest</div>
      <div class="gsap-stagger" style="display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:#3d2f3d;">
        {interests.map(item => (
          <div class="nrg-card">
            <div style="font-family:'Barlow Condensed',sans-serif;font-size:0.65rem;letter-spacing:0.2em;color:#FFC20E;margin-bottom:0.8rem;">{item.num}</div>
            <div style="font-family:'Barlow Condensed',sans-serif;font-size:1.3rem;font-weight:700;text-transform:uppercase;color:#f0e6d0;margin-bottom:0.4rem;">{item.label}</div>
            <div style="font-size:0.82rem;color:#8a7888;">{item.desc}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- 기술 스택 -->
    <div class="gsap-reveal">
      <div class="section-label" style="margin-bottom:1.5rem;">Tech Stack</div>
      <div style="display:flex;flex-wrap:wrap;gap:0.5rem;">
        {skills.map(s => (
          <span style="font-family:'Barlow Condensed',sans-serif;font-size:0.75rem;letter-spacing:0.15em;text-transform:uppercase;color:#8a7888;border:1px solid #3d2f3d;padding:0.35rem 0.8rem;transition:color 0.2s,border-color 0.2s;"
                onmouseover="this.style.color='#FFC20E';this.style.borderColor='#FFC20E'"
                onmouseout="this.style.color='#8a7888';this.style.borderColor='#3d2f3d'">
            {s}
          </span>
        ))}
      </div>
    </div>

  </section>
</BaseLayout>
