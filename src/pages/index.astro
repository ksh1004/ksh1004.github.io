---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);
---

<BaseLayout title="ksh1004 | AI & Data Engineer">
  <!-- 히어로 섹션 -->
  <section class="mb-20">
    <div class="text-[#666680] text-sm mb-4">
      <span class="text-[#00ff88]">root@ksh1004</span>:<span class="text-[#4466ff]">~</span>$ whoami
    </div>
    <h1 class="text-5xl font-bold mb-4 leading-tight">
      <span class="text-[#e0e0e0]">KIM </span>
      <span class="neon-text">SOONHA</span>
    </h1>
    <p class="text-[#666680] text-lg mb-6 cursor">
      AI / Data Engineer &nbsp;·&nbsp; OSINT &nbsp;·&nbsp; Finance
    </p>
    <p class="text-[#e0e0e0] max-w-xl leading-relaxed mb-8">
      머신러닝, 금융 데이터 분석, 한반도 OSINT 모니터링 시스템을 개발합니다.
      배운 것을 기록하고, 만든 것을 공유합니다.
    </p>
    <div class="flex gap-4 text-sm">
      <a href="/posts" class="border border-[#00ff88] text-[#00ff88] px-4 py-2 hover:bg-[#00ff8811] transition-colors">
        /posts →
      </a>
      <a href="https://velog.io/@ksh1004" target="_blank" rel="noopener"
         class="border border-[#1a1a2e] text-[#666680] px-4 py-2 hover:border-[#ffc20e] hover:text-[#ffc20e] transition-colors">
        velog ↗
      </a>
      <a href="https://github.com/ksh1004" target="_blank" rel="noopener"
         class="border border-[#1a1a2e] text-[#666680] px-4 py-2 hover:border-[#ffc20e] hover:text-[#ffc20e] transition-colors">
        github ↗
      </a>
    </div>
  </section>

  <!-- 구분선 -->
  <div class="border-t border-[#1a1a2e] mb-12"></div>

  <!-- 최근 글 -->
  <section class="mb-20">
    <div class="text-[#666680] text-sm mb-6">
      <span class="text-[#00ff88]">root@ksh1004</span>:<span class="text-[#4466ff]">~</span>$ ls -lt ./posts
    </div>

    {posts.length === 0 ? (
      <p class="text-[#666680]">// 아직 작성된 글이 없어요.</p>
    ) : (
      <div class="space-y-4">
        {posts.map(post => (
          <a href={`/posts/${post.id}`} class="neon-card block p-5 rounded-none group">
            <div class="flex items-start justify-between gap-4">
              <div>
                <h2 class="text-[#e0e0e0] font-medium mb-1 group-hover:text-[#00ff88] transition-colors">
                  {post.data.title}
                </h2>
                {post.data.description && (
                  <p class="text-[#666680] text-sm">{post.data.description}</p>
                )}
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="flex gap-2 mt-2">
                    {post.data.tags.map((tag: string) => (
                      <span class="text-xs text-[#00ff88] opacity-60">#{tag}</span>
                    ))}
                  </div>
                )}
              </div>
              <span class="text-[#666680] text-xs whitespace-nowrap">
                {post.data.date.toLocaleDateString('ko-KR', { year: 'numeric', month: '2-digit', day: '2-digit' })}
              </span>
            </div>
          </a>
        ))}
      </div>
    )}

    <div class="mt-6">
      <a href="/posts" class="text-[#666680] text-sm hover:text-[#00ff88] transition-colors">
        전체 글 보기 →
      </a>
    </div>
  </section>

  <!-- 프로젝트 섹션 -->
  <section>
    <div class="text-[#666680] text-sm mb-6">
      <span class="text-[#00ff88]">root@ksh1004</span>:<span class="text-[#4466ff]">~</span>$ ls ./projects
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {[
        { name: 'IntelligenceView', desc: '한반도 OSINT 4D 모니터링 대시보드', tag: 'Python / CesiumJS', url: 'https://github.com/ksh1004' },
        { name: 'System Trading', desc: '한국·미국 주식 자동매매 시스템', tag: 'Python / 백테스팅', url: 'https://github.com/ksh1004' },
        { name: 'Military Vehicle AI', desc: '군용 차량 이미지 분류 모델', tag: 'PyTorch / CNN', url: 'https://github.com/ksh1004' },
        { name: 'News Credibility', desc: '뉴스 정치 편향 분석기', tag: 'NLP / Streamlit', url: 'https://github.com/ksh1004' },
      ].map(proj => (
        <a href={proj.url} target="_blank" rel="noopener" class="neon-card p-4 group block">
          <div class="flex items-start justify-between mb-2">
            <h3 class="text-[#e0e0e0] font-medium group-hover:text-[#00ff88] transition-colors">
              {proj.name}
            </h3>
            <span class="text-[#666680] text-xs">↗</span>
          </div>
          <p class="text-[#666680] text-sm mb-3">{proj.desc}</p>
          <span class="text-xs text-[#ffc20e] opacity-70">{proj.tag}</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
