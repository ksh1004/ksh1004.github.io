---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6);

const projects = [
  { num: '01', name: 'IntelligenceView', desc: '한반도 공개출처정보 자동 수집 및 4D 시각화 대시보드.', stack: 'Python · CesiumJS · SQLite', url: 'https://github.com/ksh1004' },
  { num: '02', name: 'System Trading', desc: '한국·미국 주식 자동매매 시스템. 백테스팅부터 자동 체결까지.', stack: 'Python · Backtrader', url: 'https://github.com/ksh1004' },
  { num: '03', name: 'Military Vehicle AI', desc: '군용 차량 이미지 분류 모델. CNN 기반 다중 클래스.', stack: 'PyTorch · CNN', url: 'https://github.com/ksh1004' },
  { num: '04', name: 'News Bias Analyzer', desc: '뉴스 기사 정치 편향 분석 및 시각화.', stack: 'NLP · Streamlit', url: 'https://github.com/ksh1004' },
];
---

<BaseLayout title="KSH1004 — 김순하">

  <!-- ═══ HERO ═══ -->
  <section style="background:#000;padding:120px 40px 96px;min-height:100svh;display:flex;flex-direction:column;justify-content:flex-end;position:relative;overflow:hidden;">

    <!-- 메인 헤드라인 -->
    <div id="hero-hl" style="position:relative;z-index:1;">
      <h1 style="font-size:clamp(4rem,12vw,10rem);font-weight:700;line-height:1;text-transform:uppercase;letter-spacing:-0.02em;color:#fff;margin-bottom:0;">
        KIM<br/>SOONHA.
      </h1>
    </div>

    <!-- M 스트라이프 구분선 -->
    <div class="m-stripe gsap-line" style="margin:40px 0 32px;"><span></span><span></span><span></span></div>

    <!-- 서브헤드 + CTA -->
    <div id="hero-sub" style="display:flex;align-items:flex-end;justify-content:space-between;gap:40px;position:relative;z-index:1;flex-wrap:wrap;">
      <p style="font-size:17px;font-weight:300;color:#bbbbbb;max-width:440px;line-height:1.65;">
        개발, 금융 데이터, 정보분석에 관심 있는 학생입니다.<br/>
        공부한 것을 기록하고 만든 것을 공유합니다.
      </p>
      <div style="display:flex;gap:16px;flex-shrink:0;">
        <a href="/posts" class="btn" data-cursor-hover>글 보기</a>
        <a href="/about" class="btn"
           style="border-color:#3c3c3c;color:#7e7e7e;"
           onmouseover="this.style.borderColor='#fff';this.style.color='#fff'"
           onmouseout="this.style.borderColor='#3c3c3c';this.style.color='#7e7e7e'"
           data-cursor-hover>소개</a>
      </div>
    </div>

    <!-- 스크롤 인디케이터 -->
    <div id="scroll-ind" style="position:absolute;bottom:40px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:8px;">
      <span style="font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:#3c3c3c;">Scroll</span>
      <div style="width:1px;height:40px;background:linear-gradient(to bottom,#3c3c3c,transparent);"></div>
    </div>
  </section>

  <!-- ═══ RECENT POSTS ═══ -->
  <section style="background:#000;padding:96px 40px;border-top:1px solid #3c3c3c;">
    <div style="max-width:1440px;margin:0 auto;">

      <div class="gsap-reveal" style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:40px;flex-wrap:wrap;gap:16px;">
        <div>
          <div class="label-upper" style="margin-bottom:12px;">Latest</div>
          <h2 style="font-size:clamp(2rem,5vw,3.5rem);font-weight:700;text-transform:uppercase;color:#fff;line-height:1.05;">Posts</h2>
        </div>
        <a href="/posts"
           style="font-size:13px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:#7e7e7e;text-decoration:none;transition:color 0.15s;"
           onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#7e7e7e'"
           data-cursor-hover>
          전체 보기 →
        </a>
      </div>

      <hr class="hairline gsap-line" style="margin-bottom:0;" />

      <div class="gsap-stagger">
        {posts.length === 0 ? (
          <div style="padding:64px 0;font-size:14px;font-weight:300;color:#3c3c3c;">
            아직 작성된 글이 없습니다.
          </div>
        ) : posts.map((post, i) => (
          <a href={`/posts/${post.id}`}
             style="display:flex;align-items:baseline;justify-content:space-between;gap:40px;padding:24px 0;border-bottom:1px solid #3c3c3c;text-decoration:none;"
             data-cursor-hover
             onmouseover="this.querySelector('.pt').style.color='#fff'"
             onmouseout="this.querySelector('.pt').style.color='#e6e6e6'">
            <div style="display:flex;align-items:baseline;gap:24px;min-width:0;">
              <span style="font-size:12px;font-weight:400;letter-spacing:0.5px;color:#3c3c3c;width:24px;flex-shrink:0;">
                {String(i+1).padStart(2,'0')}
              </span>
              <div>
                <div class="pt" style="font-size:19px;font-weight:700;text-transform:uppercase;color:#e6e6e6;transition:color 0.15s;line-height:1.3;">
                  {post.data.title}
                </div>
                {post.data.description && (
                  <div style="font-size:14px;font-weight:300;color:#7e7e7e;margin-top:4px;">{post.data.description}</div>
                )}
              </div>
            </div>
            <div style="display:flex;align-items:center;gap:16px;flex-shrink:0;">
              {post.data.category && (
                <span style="font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:#3c3c3c;border:1px solid #3c3c3c;padding:4px 10px;">
                  {post.data.category}
                </span>
              )}
              <span style="font-size:12px;font-weight:400;letter-spacing:0.5px;color:#7e7e7e;white-space:nowrap;">
                {post.data.date.toLocaleDateString('ko-KR',{year:'numeric',month:'2-digit',day:'2-digit'})}
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ PROJECTS ═══ -->
  <section style="background:#0d0d0d;padding:96px 40px;border-top:1px solid #3c3c3c;">
    <div style="max-width:1440px;margin:0 auto;">

      <div class="gsap-reveal" style="margin-bottom:40px;">
        <div class="label-upper" style="margin-bottom:12px;">Selected</div>
        <h2 style="font-size:clamp(2rem,5vw,3.5rem);font-weight:700;text-transform:uppercase;color:#fff;line-height:1.05;">Projects</h2>
      </div>

      <hr class="hairline gsap-line" style="margin-bottom:40px;" />

      <div class="gsap-stagger" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1px;background:#3c3c3c;">
        {projects.map(proj => (
          <a href={proj.url} target="_blank" rel="noopener"
             class="m-card"
             style="background:#0d0d0d;text-decoration:none;display:flex;flex-direction:column;gap:12px;"
             data-cursor-hover
             onmouseover="this.style.background='#1a1a1a'" onmouseout="this.style.background='#0d0d0d'">
            <div style="font-size:12px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:#3c3c3c;">{proj.num}</div>
            <div style="font-size:22px;font-weight:700;text-transform:uppercase;color:#fff;line-height:1.3;">{proj.name}</div>
            <div style="font-size:14px;font-weight:300;color:#7e7e7e;line-height:1.6;flex:1;">{proj.desc}</div>
            <div class="m-stripe" style="height:2px;margin-top:8px;"><span></span><span></span><span></span></div>
            <div style="font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:#3c3c3c;">{proj.stack}</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ CTA BAND ═══ -->
  <section style="background:#000;padding:96px 40px;border-top:1px solid #3c3c3c;text-align:center;">
    <div style="max-width:1440px;margin:0 auto;" class="gsap-reveal">
      <div class="label-upper" style="margin-bottom:24px;text-align:center;">Contact</div>
      <h2 style="font-size:clamp(2rem,5vw,3.5rem);font-weight:700;text-transform:uppercase;color:#fff;margin-bottom:40px;line-height:1.1;">
        Let's Work Together.
      </h2>
      <a href="mailto:soonha990@naver.com" class="btn" data-cursor-hover>연락하기</a>
    </div>
  </section>

</BaseLayout>

<script>
import gsap from 'gsap';

gsap.timeline({ defaults: { ease: 'power4.out' } })
  .from('#hero-hl h1', { y: 60, opacity: 0, duration: 1.0 })
  .from('#hero-sub', { opacity: 0, y: 20, duration: 0.7 }, '-=0.5')
  .from('#scroll-ind', { opacity: 0, duration: 0.5 }, '-=0.3');

gsap.to('#scroll-ind > div', {
  scaleY: 0, transformOrigin: 'top',
  duration: 1.0, ease: 'power2.in',
  repeat: -1, repeatDelay: 0.6,
});
</script>
