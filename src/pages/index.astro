---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6);

const projects = [
  { num: '01', name: 'IntelligenceView', desc: '한반도 공개출처정보 자동 수집 및 4D 시각화 대시보드.', stack: 'Python · CesiumJS · SQLite', url: 'https://github.com/ksh1004' },
  { num: '02', name: 'System Trading',   desc: '한국·미국 주식 자동매매 시스템. 백테스팅부터 자동 체결까지.', stack: 'Python · Backtrader', url: 'https://github.com/ksh1004' },
  { num: '03', name: 'Military Vehicle AI', desc: '군용 차량 이미지 분류 모델. CNN 기반 다중 클래스.', stack: 'PyTorch · CNN', url: 'https://github.com/ksh1004' },
  { num: '04', name: 'News Bias Analyzer', desc: '뉴스 기사 정치 편향 분석 및 시각화.', stack: 'NLP · Streamlit', url: 'https://github.com/ksh1004' },
];
---

<BaseLayout title="KSH·1004 — 김순하">

  <!-- ═══ HERO ═══ -->
  <section style="background:var(--canvas);padding:96px 40px;min-height:100svh;display:flex;flex-direction:column;justify-content:flex-end;position:relative;overflow:hidden;">

    <!-- 배경 격자 -->
    <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(28,42,30,0.35) 1px,transparent 1px),linear-gradient(90deg,rgba(28,42,30,0.35) 1px,transparent 1px);background-size:72px 72px;pointer-events:none;"></div>

    <!-- 우상단 상태 표시 -->
    <div style="position:absolute;top:40px;right:40px;" class="gsap-reveal">
      <div style="display:inline-flex;align-items:center;gap:6px;border:1px solid var(--green-dim);padding:5px 14px;background:var(--green-glow);">
        <div style="width:5px;height:5px;background:var(--green);border-radius:50%;" id="status-dot"></div>
        <span style="font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--green);">Online</span>
      </div>
    </div>

    <!-- 메인 헤드라인 -->
    <div id="hero-hl" style="position:relative;z-index:1;">
      <h1 style="font-size:clamp(3.5rem,10vw,9rem);font-weight:700;line-height:0.95;text-transform:uppercase;letter-spacing:-0.02em;color:var(--ink);">
        KIM<br/>SOONHA.
      </h1>
    </div>

    <!-- 구분선 -->
    <div class="intel-stripe gsap-line" style="margin:36px 0 28px;"></div>

    <!-- 서브 -->
    <div id="hero-sub" style="display:flex;align-items:flex-end;justify-content:space-between;gap:40px;position:relative;z-index:1;flex-wrap:wrap;">
      <p style="font-size:14px;font-weight:300;color:var(--body);max-width:400px;line-height:1.85;letter-spacing:0.3px;">
        개발, 금융 데이터, 정보분석에 관심 있는 학생.<br/>공부한 것을 기록하고 만든 것을 공유한다.
      </p>
      <div style="display:flex;gap:12px;flex-shrink:0;flex-wrap:wrap;">
        <a href="/posts" class="btn" data-cursor-hover>Posts</a>
        <a href="/about"
           style="display:inline-flex;align-items:center;padding:13px 28px;font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;text-decoration:none;border:1px solid var(--hairline-strong);color:var(--muted);transition:border-color 0.2s,color 0.2s;font-family:inherit;"
           onmouseover="this.style.borderColor='var(--muted)';this.style.color='var(--body)'"
           onmouseout="this.style.borderColor='var(--hairline-strong)';this.style.color='var(--muted)'"
           data-cursor-hover>About</a>
      </div>
    </div>

    <!-- 스크롤 힌트 -->
    <div id="scroll-ind" style="position:absolute;bottom:40px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:6px;">
      <div style="width:1px;height:36px;background:linear-gradient(to bottom,var(--green),transparent);"></div>
    </div>
  </section>

  <!-- ═══ STATS ═══ -->
  <section style="background:var(--surface-soft);border-top:1px solid var(--hairline);border-bottom:1px solid var(--hairline);">
    <div style="max-width:1440px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);">
      {[
        { val: 'Seoul', label: 'Location' },
        { val: '인하대', label: 'University' },
        { val: '개발', label: 'Focus' },
        { val: '2026', label: 'Est.' },
      ].map((s, i) => (
        <div class="spec-cell" style={`border-radius:0;border:none;border-right:${i<3?'1px solid var(--hairline)':'none'};`}>
          <div class="val">{s.val}</div>
          <div class="spec-label">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══ POSTS ═══ -->
  <section style="background:var(--canvas);padding:96px 40px;border-bottom:1px solid var(--hairline);">
    <div style="max-width:1440px;margin:0 auto;">

      <div class="gsap-reveal" style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:40px;flex-wrap:wrap;gap:16px;">
        <div>
          <div class="label-upper" style="margin-bottom:12px;">Recent</div>
          <h2 style="font-size:clamp(1.8rem,4vw,3rem);font-weight:700;text-transform:uppercase;color:var(--ink);line-height:1.05;letter-spacing:0.5px;">Posts</h2>
        </div>
        <a href="/posts"
           style="font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--muted);text-decoration:none;transition:color 0.15s;"
           onmouseover="this.style.color='var(--green)'" onmouseout="this.style.color='var(--muted)'"
           data-cursor-hover>View All →</a>
      </div>

      <div class="intel-stripe gsap-line" style="margin-bottom:0;"></div>

      <div class="gsap-stagger">
        {posts.length === 0 ? (
          <div style="padding:64px 0;font-size:12px;letter-spacing:1px;color:var(--hairline-strong);">No posts yet.</div>
        ) : posts.map((post, i) => (
          <a href={`/posts/${post.id}`}
             style="display:flex;align-items:baseline;justify-content:space-between;gap:40px;padding:24px 0;border-bottom:1px solid var(--hairline);text-decoration:none;transition:background 0.15s;"
             data-cursor-hover
             onmouseover="this.querySelector('.pt').style.color='var(--ink)';this.style.background='var(--green-glow)'"
             onmouseout="this.querySelector('.pt').style.color='var(--body-strong)';this.style.background='transparent'">
            <div style="display:flex;align-items:baseline;gap:24px;min-width:0;">
              <span style="font-size:11px;color:var(--hairline-strong);width:24px;flex-shrink:0;letter-spacing:1px;">{String(i+1).padStart(2,'0')}</span>
              <div>
                <div class="pt" style="font-size:17px;font-weight:700;text-transform:uppercase;color:var(--body-strong);transition:color 0.15s;line-height:1.3;letter-spacing:0.3px;">{post.data.title}</div>
                {post.data.description && (
                  <div style="font-size:12px;font-weight:300;color:var(--muted);margin-top:4px;letter-spacing:0.3px;">{post.data.description}</div>
                )}
              </div>
            </div>
            <div style="display:flex;align-items:center;gap:10px;flex-shrink:0;">
              {post.data.category && <span class="badge-muted">{post.data.category}</span>}
              <span style="font-size:11px;letter-spacing:1px;color:var(--muted);white-space:nowrap;">
                {post.data.date.toLocaleDateString('ko-KR',{year:'numeric',month:'2-digit',day:'2-digit'})}
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ PROJECTS ═══ -->
  <section style="background:var(--surface-soft);padding:96px 40px;border-bottom:1px solid var(--hairline);">
    <div style="max-width:1440px;margin:0 auto;">

      <div class="gsap-reveal" style="margin-bottom:40px;">
        <div class="label-upper" style="margin-bottom:12px;">Selected</div>
        <h2 style="font-size:clamp(1.8rem,4vw,3rem);font-weight:700;text-transform:uppercase;color:var(--ink);line-height:1.05;letter-spacing:0.5px;">Projects</h2>
      </div>

      <div class="intel-stripe gsap-line" style="margin-bottom:40px;"></div>

      <div class="gsap-stagger" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1px;background:var(--hairline);">
        {projects.map(proj => (
          <a href={proj.url} target="_blank" rel="noopener"
             class="intel-card"
             style="background:var(--surface-card);text-decoration:none;display:flex;flex-direction:column;gap:12px;"
             data-cursor-hover
             onmouseover="this.style.background='var(--surface-elevated)'" onmouseout="this.style.background='var(--surface-card)'">
            <div style="font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);">{proj.num}</div>
            <div style="font-size:18px;font-weight:700;text-transform:uppercase;color:var(--ink);line-height:1.3;letter-spacing:0.3px;">{proj.name}</div>
            <div style="font-size:12px;font-weight:300;color:var(--body);line-height:1.75;flex:1;letter-spacing:0.3px;">{proj.desc}</div>
            <div style="font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--green-dim);">{proj.stack}</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ CTA ═══ -->
  <section style="background:var(--canvas);padding:96px 40px;text-align:center;">
    <div style="max-width:1440px;margin:0 auto;" class="gsap-reveal">
      <div class="label-upper" style="margin-bottom:24px;text-align:center;">Contact</div>
      <h2 style="font-size:clamp(1.8rem,4vw,3rem);font-weight:700;text-transform:uppercase;color:var(--ink);margin-bottom:40px;line-height:1.1;letter-spacing:0.5px;">
        Establish Contact.
      </h2>
      <a href="mailto:soonha990@naver.com" class="btn" data-cursor-hover>Send Message</a>
    </div>
  </section>

</BaseLayout>

<style>
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }
#status-dot { animation: pulse 3s ease-in-out infinite; }
</style>

<script>
import gsap from 'gsap';
gsap.timeline({ defaults: { ease: 'power4.out' } })
  .from('#hero-hl', { y: 50, opacity: 0, duration: 1.0 })
  .from('#hero-sub', { opacity: 0, y: 20, duration: 0.7 }, '-=0.5')
  .from('#scroll-ind', { opacity: 0, duration: 0.5 }, '-=0.3');
gsap.to('#scroll-ind > div', { scaleY: 0, transformOrigin: 'top', duration: 1.0, ease: 'power2.in', repeat: -1, repeatDelay: 0.5 });
</script>
