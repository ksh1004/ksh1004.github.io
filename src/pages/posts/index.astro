---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categories = ['개발', '프로젝트', '코딩테스트', '일상'];

const SUB_CATEGORIES: Record<string, string[]> = {
  '코딩테스트': ['C++', 'Python', 'Java'],
};
---

<BaseLayout title="Posts — KSH1004">

  <section style="background:var(--canvas);padding:72px 40px 0;border-bottom:1px solid var(--hairline);">
    <div style="max-width:1440px;margin:0 auto;">

      <div class="gsap-reveal" style="margin-bottom:40px;">
        <div class="label-upper" style="margin-bottom:12px;">Archive · {posts.length}편</div>
        <h1 style="font-size:clamp(2.5rem,7vw,5rem);font-weight:700;text-transform:uppercase;color:var(--ink);line-height:1;letter-spacing:0.3px;">
          Posts
        </h1>
      </div>

      <!-- 카테고리 탭 -->
      <div style="display:flex;gap:0;overflow-x:auto;scrollbar-width:none;" class="gsap-reveal">
        <button class="cat-tab active" data-cat="all"
          style="font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--ink);padding:16px 24px;border:none;border-bottom:2px solid var(--green);background:none;cursor:none;white-space:nowrap;transition:color 0.15s,border-color 0.15s;font-family:inherit;">
          전체
        </button>
        {categories.map(cat => (
          <button class="cat-tab" data-cat={cat}
            style="font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--muted);padding:16px 24px;border:none;border-bottom:2px solid transparent;background:none;cursor:none;white-space:nowrap;transition:color 0.15s,border-color 0.15s;font-family:inherit;">
            {cat}
          </button>
        ))}
      </div>

      <!-- 하위 카테고리 -->
      <div id="sub-tab-bar" style="display:none;background:var(--surface-soft);margin:0 -40px;padding:0 40px;border-top:1px solid var(--hairline);">
        <div id="sub-tabs" style="display:flex;gap:0;"></div>
      </div>
    </div>
  </section>

  <section style="background:var(--canvas);padding:0 40px 96px;">
    <div style="max-width:1440px;margin:0 auto;">

      <div id="post-list">
        {posts.length === 0 ? (
          <div style="padding:80px 0;font-size:12px;letter-spacing:1px;color:var(--hairline-strong);">No posts yet.</div>
        ) : posts.map((post, i) => (
          <a
            href={`/posts/${post.id}`}
            class="post-item"
            data-category={post.data.category ?? '개발'}
            data-subcategory={post.data.subcategory ?? ''}
            style="display:flex;align-items:baseline;justify-content:space-between;gap:40px;padding:28px 0;border-bottom:1px solid var(--hairline);text-decoration:none;transition:background 0.15s;"
            data-cursor-hover
            onmouseover="this.querySelector('.pt').style.color='var(--ink)';this.style.background='var(--green-glow)'"
            onmouseout="this.querySelector('.pt').style.color='var(--body-strong)';this.style.background='transparent'">
            <div style="display:flex;align-items:baseline;gap:24px;min-width:0;">
              <span style="font-size:11px;color:var(--hairline-strong);width:28px;flex-shrink:0;letter-spacing:1px;">{String(i+1).padStart(2,'0')}</span>
              <div>
                <div class="pt" style="font-size:17px;font-weight:700;text-transform:uppercase;color:var(--body-strong);transition:color 0.15s;line-height:1.3;letter-spacing:0.3px;">{post.data.title}</div>
                {post.data.description && (
                  <div style="font-size:12px;font-weight:300;color:var(--muted);margin-top:4px;letter-spacing:0.3px;">{post.data.description}</div>
                )}
              </div>
            </div>
            <div style="display:flex;align-items:center;gap:10px;flex-shrink:0;">
              {post.data.subcategory && <span class="badge-green">{post.data.subcategory}</span>}
              <span class="badge-muted">{post.data.category ?? '개발'}</span>
              <span style="font-size:11px;letter-spacing:1px;color:var(--muted);white-space:nowrap;">
                {post.data.date.toLocaleDateString('ko-KR',{year:'numeric',month:'2-digit',day:'2-digit'})}
              </span>
            </div>
          </a>
        ))}
      </div>

      <div id="empty-msg" style="display:none;padding:64px 0;font-size:12px;letter-spacing:1px;color:var(--hairline-strong);">
        해당 카테고리의 글이 없습니다.
      </div>
    </div>
  </section>

</BaseLayout>

<script>
const SUB_CATEGORIES: Record<string, string[]> = {
  '코딩테스트': ['C++', 'Python', 'Java'],
};
const mainTabs  = document.querySelectorAll<HTMLButtonElement>('.cat-tab');
const items     = document.querySelectorAll<HTMLElement>('.post-item');
const subBar    = document.getElementById('sub-tab-bar')!;
const subTabsEl = document.getElementById('sub-tabs')!;
const emptyMsg  = document.getElementById('empty-msg')!;
let currentCat  = 'all';

function setActiveMain(btn: HTMLButtonElement) {
  mainTabs.forEach(t => { t.style.color = 'var(--muted)'; t.style.borderBottomColor = 'transparent'; });
  btn.style.color = 'var(--ink)';
  btn.style.borderBottomColor = 'var(--green)';
}

function subStyle(btn: HTMLButtonElement, active: boolean) {
  btn.style.cssText = `font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;
    padding:12px 20px;border:none;border-bottom:2px solid ${active?'var(--green-dim)':'transparent'};
    background:none;cursor:none;white-space:nowrap;font-family:inherit;
    color:${active?'var(--green)':'var(--muted)'};transition:color 0.15s,border-color 0.15s;`;
}

function renderSubTabs(subs: string[]) {
  subTabsEl.innerHTML = '';
  if (!subs.length) { subBar.style.display = 'none'; return; }
  subBar.style.display = 'block';
  const all = document.createElement('button');
  all.textContent = '전체'; all.dataset.sub = 'all';
  subStyle(all, true);
  all.addEventListener('click', () => { subStyle(all, true); subTabsEl.querySelectorAll<HTMLButtonElement>('button:not(:first-child)').forEach(b => subStyle(b, false)); filterPosts(currentCat,'all'); });
  subTabsEl.appendChild(all);
  subs.forEach(sub => {
    const btn = document.createElement('button');
    btn.textContent = sub; btn.dataset.sub = sub;
    subStyle(btn, false);
    btn.addEventListener('click', () => {
      subTabsEl.querySelectorAll<HTMLButtonElement>('button').forEach(b => subStyle(b, false));
      subStyle(btn, true);
      filterPosts(currentCat, sub);
    });
    subTabsEl.appendChild(btn);
  });
}

function filterPosts(cat: string, sub: string) {
  let visible = 0;
  items.forEach(item => {
    const ok = (cat === 'all' || item.dataset.category === cat) && (sub === 'all' || item.dataset.subcategory === sub);
    item.style.display = ok ? '' : 'none';
    if (ok) visible++;
  });
  emptyMsg.style.display = visible === 0 ? 'block' : 'none';
}

mainTabs.forEach(btn => {
  btn.addEventListener('click', () => {
    const cat = btn.dataset.cat ?? 'all';
    currentCat = cat;
    setActiveMain(btn);
    renderSubTabs(cat !== 'all' && SUB_CATEGORIES[cat] ? SUB_CATEGORIES[cat] : []);
    filterPosts(cat, 'all');
  });
});
</script>
